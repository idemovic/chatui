# ── Public mode ───────────────────────────────────────────────────────────────
# Set to "true" to hide the Settings UI and load all configuration from
# VITE_CONFIG_URL at runtime (after build). Intended for production deployments.
# Set to "false" (or omit) during development to keep the settings panel visible.
VITE_PUBLIC_MODE=false

# URL of the runtime JSON config file, relative to the deployed root.
# Defaults to /chat-config.json when omitted.
# The file is fetched by the browser on every page load, so you can update it
# on the server without rebuilding.
VITE_CONFIG_URL=/chat-config.json
